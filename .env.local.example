# ======================
# Supabase
# ======================
# フロントエンド（ブラウザ）からアクセスするURL・匿名キー
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# サーバーサイド専用（フロントエンドに絶対に漏らさないこと）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ======================
# LINE LIFF
# ======================
# LIFF アプリID（フロントエンドで使用）
NEXT_PUBLIC_LIFF_ID=your-liff-id

# ======================
# LINE Messaging API
# ======================
# サーバーサイド専用（フロントエンドに絶対に漏らさないこと）
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret

# ======================
# アプリケーション設定
# ======================
# 本番URL（LIFF のコールバックURLなどに使用）
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ======================
# セキュリティ注意事項
# ======================
# - NEXT_PUBLIC_ 接頭辞のある変数のみブラウザに公開されます
# - SUPABASE_SERVICE_ROLE_KEY は管理者権限を持つため、絶対にフロントエンドで使用しないでください
# - LINE_CHANNEL_ACCESS_TOKEN / LINE_CHANNEL_SECRET もサーバーサイド専用です
# - このファイルをコピーして .env.local を作成してください
